            local ProjectileInflict = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ProjectileInflict")
            if not (FireProjectile and ProjectileInflict) then return end
            if not (hookmetamethod and getnamecallmethod) then return end
